# ---- Gemini AI ----
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ---- Security (REQUIRED in production) ----
# Long random string used to sign auth tokens (JWT). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret"

# ---- WebAuthn (biometric login) ----
# RP_ID = your domain WITHOUT scheme/port ('localhost' for local dev)
RP_ID="localhost"
RP_NAME="StockWise ES"
# ORIGIN = full origin incl. scheme (MUST be https in production)
ORIGIN="http://localhost:3000"

# ---- Server ----
PORT="3000"
# Where the JSON data store is written (use a persistent disk path in prod)
DB_FILE="./data_store.json"
